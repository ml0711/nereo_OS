# --- Microsoft Graph (SharePoint + Outlook: Lesen + abgesichertes Schreiben) ---
# Diese Credentials gehören in die HOST-Umgebung, in der der Crawl (graph:export) läuft.
MS_TENANT_ID=
MS_CLIENT_ID=
MS_CLIENT_SECRET=
# Schreiben braucht Application-Permission Sites.ReadWrite.All + Mail.Send (Admin-Consent in Azure).
# Ops-Kill-Switch: Schreib-Endpoints (/api/write/*) UND der mutate()-Backstop sind AUS,
# solange das hier nicht =1 ist. Ohne =1 wird keine Mutation ans Netz geschickt.
GRAPH_WRITE_ENABLED=0

# --- App-Daten / Analyse-Zwischenspeicher: self-hosted Postgres (Coolify, DB nereo_app) ---
# KEIN Supabase mehr (Entscheidung 2026-06: Daten bleiben auf dem VPS, siehe CLAUDE.md §2/§3).
DATABASE_URL=postgres://user:pass@host:5432/nereo_app
# Optional: wie viele Index-Versionen in graph_index behalten werden (Pruning, Default 5).
GRAPH_INDEX_KEEP=5

# --- LogTo (self-hosted Auth) — nur die App ist OIDC-Client, die Landing nicht ---
LOGTO_ENDPOINT=
LOGTO_APP_ID=
LOGTO_APP_SECRET=

# --- KI-Inferenz (Claude API) ---
# Build-Phase: Claude (US). Vor institutionellem Go-Live ggf. EU-Endpoint (CLAUDE.md §5.4).
ANTHROPIC_API_KEY=
# Optional: Modell-Override (Default: claude-haiku-4-5, günstig).
ANTHROPIC_MODEL=

# --- App ---
APP_BASE_URL=http://localhost:3000
# Signiert die Session-Cookies. In Produktion zwingend setzen (sonst pro Neustart neu = Logout).
SESSION_SECRET=
# Schützt die BULK-Analyse (curl/cron) — als HTTP-Header `X-Analyze-Token`, nicht als URL-Query.
ANALYZE_TRIGGER_SECRET=
