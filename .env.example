# --- Microsoft Graph (SharePoint + Outlook: Lesen + abgesichertes Schreiben) ---
# Diese Credentials gehören in die HOST-Umgebung, in der der Crawl (graph:export) läuft.
MS_TENANT_ID=
MS_CLIENT_ID=
MS_CLIENT_SECRET=
# Schreiben braucht Application-Permission Sites.ReadWrite.All + Mail.Send (Admin-Consent in Azure).
# Ops-Kill-Switch: Schreib-Endpoints (/api/write/*) UND der mutate()-Backstop sind AUS,
# solange das hier nicht =1 ist. Ohne =1 wird keine Mutation ans Netz geschickt.
GRAPH_WRITE_ENABLED=0

# --- App-Daten / Analyse-Zwischenspeicher: self-hosted Postgres (Coolify, DB nereo_app) ---
# KEIN Supabase mehr (Entscheidung 2026-06: Daten bleiben auf dem VPS, siehe CLAUDE.md §2/§3).
DATABASE_URL=postgres://user:pass@host:5432/nereo_app
# Optional: wie viele Index-Versionen in graph_index behalten werden (Pruning, Default 5).
GRAPH_INDEX_KEEP=5

# --- LogTo (self-hosted Auth) — nur die App ist OIDC-Client, die Landing nicht ---
LOGTO_ENDPOINT=
LOGTO_APP_ID=
LOGTO_APP_SECRET=

# --- KI-Inferenz (Claude API) ---
# Build-Phase: Claude (US). Vor institutionellem Go-Live ggf. EU-Endpoint (CLAUDE.md §5.4).
ANTHROPIC_API_KEY=
# Optional: Modell-Override (Default: claude-haiku-4-5, günstig).
ANTHROPIC_MODEL=

# --- Workspace-Wurzel (Business as Code) — die App spiegelt die SharePoint-Struktur ab DIESEM Ordner ---
# Die fixe Wurzel ist der Ausgangspunkt der gesamten App (Sidebar = ihre Top-Level-Kinder).
# Bevorzugt die ids PINNEN (stabil, sonderzeichen-immun, überleben Umbenennung) — die App
# loggt sie beim ersten Bootstrap-Auflösen. Werte für nereo Development Partners (Stand 2026-06):
WORKSPACE_ROOT_DRIVE_ID=b!b3JadkMulkOjvymbrQC304UVoLJMIWRJqLFcoiiCTuEsJWYtAgH6RLo4Tib7hDPO
WORKSPACE_ROOT_ITEM_ID=01WIB5NTE52CYSPR3AVBC3WYUW7O7YKEEO
# Bootstrap-Fallback, falls ids NICHT gepinnt sind (Owner-OneDrive + Ordnername):
WORKSPACE_ROOT_UPN=kienle@nereo.ch
WORKSPACE_ROOT_FOLDER=nereo Development Partners

# --- Realtime-Sync (Graph-Webhooks, CLAUDE.md §3) ---
# Subscription-Lebensdauer + Erneuerungs-Puffer (Minuten). Default 7d/2d, sicher unter dem ~30d-Max.
# Falls Graph beim Create eine kürzere expiration zurückgibt, wird DIESE übernommen.
GRAPH_SUB_LIFETIME_MIN=10080
GRAPH_SUB_RENEW_BEFORE_MIN=2880
# Optional: schützt den HTTP-Renew-Trigger /api/graph/renew (Header X-Graph-Cron). Primärer Renew-Weg
# ist die CLI 'graph:subscribe' als Coolify Scheduled Task — dann ist dieser Endpoint nicht nötig.
GRAPH_CRON_SECRET=

# --- App ---
APP_BASE_URL=http://localhost:3000
# Signiert die Session-Cookies. In Produktion zwingend setzen (sonst pro Neustart neu = Logout).
SESSION_SECRET=
# Schützt die BULK-Analyse (curl/cron) — als HTTP-Header `X-Analyze-Token`, nicht als URL-Query.
ANALYZE_TRIGGER_SECRET=
